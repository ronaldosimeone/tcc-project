# ── Banco de Dados (Rede Docker) ──────────────────────────────────────
POSTGRES_USER=seu_usuario_aqui
POSTGRES_PASSWORD=sua_senha_segura_aqui
POSTGRES_DB=tcc_db
DATABASE_URL=postgresql+asyncpg://seu_usuario_aqui:sua_senha_segura_aqui@db:5432/tcc_db

# ── Machine Learning (RF-10 / RNF-09) ─────────────────────────────────
# Seleção do modelo ativo no contêiner (random_forest ou xgboost)
ACTIVE_MODEL=xgboost
# Estratégia de balanceamento do SMOTE
SMOTE_SAMPLING_STRATEGY=auto

# ── Configurações da API ──────────────────────────────────────────────
PROJECT_NAME="TCC Manutenção Preditiva"
VERSION="1.0.0"
ALLOWED_ORIGINS='["http://localhost:3000", "http://127.0.0.1:3000", "http://localhost:8000"]'

# ── IA Local (Docker -> Host) ─────────────────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434