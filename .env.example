POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=tcc_db

# ML — Class Balancing (RF-03 / RNF-09)
# Controls SMOTE oversampling ratio for the training split.
# Accepted values:
#   "auto"          → balance all classes to match the majority count (default)
#   "minority"      → resample only the minority class
#   "not majority"  → resample all classes except the majority
#   0.0 < x <= 1.0  → explicit minority/majority ratio (e.g. 0.5 = 1:2 ratio)
SMOTE_SAMPLING_STRATEGY=auto
